# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 100

[*.{yaml,yml,base}]
indent_size = 2

[*.md]
indent_size = 2
# markdown uses trailing spaces for hard line breaks; keep them
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
